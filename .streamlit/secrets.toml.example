# =============================================================================
# PhaDataPro AI — пример файла секретов
# =============================================================================
# Скопируйте этот файл: cp .streamlit/secrets.toml.example .streamlit/secrets.toml
# Заполните реальными значениями. НИКОГДА не коммитьте secrets.toml в Git.
#
# Streamlit Cloud: App settings → Secrets → вставьте содержимое ниже.
# =============================================================================

# --- OpenAI ---
OPENAI_API_KEY = "sk-proj-YOUR_KEY_HERE"

# --- Авторизация ---
# Администратор видит чат + панель администрирования (все логи).
# Пользователь видит только чат.
[auth]
admin_login    = "admin"
admin_password = "STRONG_ADMIN_PASSWORD_HERE"

user1_login    = "viortis"
user1_password = "STRONG_CLIENT_PASSWORD_HERE"

# Добавьте user2_login/user2_password для второго клиента и т.д.:
# user2_login    = "client2"
# user2_password = "PASSWORD2"
